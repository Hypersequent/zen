// @zod-version: v4
// @typecheck
export const PayloadSchema = z.object({
  Address: z.union([z.string().check(z.ipv4()).min(1).refine((val) => [...val].length <= 45, 'String must contain at most 45 character(s)'), z.string().check(z.ipv6()).min(1).refine((val) => [...val].length <= 45, 'String must contain at most 45 character(s)')]),
})
export type Payload = z.infer<typeof PayloadSchema>


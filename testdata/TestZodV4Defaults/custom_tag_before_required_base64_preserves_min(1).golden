// @zod-version: v4
// @typecheck
export const PayloadSchema = z.object({
  Data: z.string().trim().min(1).regex(/^(?:[A-Za-z0-9+\/]{4})*(?:[A-Za-z0-9+\/]{2}==|[A-Za-z0-9+\/]{3}=|[A-Za-z0-9+\/]{4})$/),
  Hex: z.string().trim().min(1).regex(/^(0[xX])?[0-9a-fA-F]+$/),
})
export type Payload = z.infer<typeof PayloadSchema>

